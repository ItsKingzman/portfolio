---
import { config } from '../data/config.js';
---

<section class="stats ml-[280px] py-16 border-t border-[#333]">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="stats-grid grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-12">
      {config.stats.map((stat, index) => (
        <div class="stat-card text-center opacity-0 translate-y-8 scale-90 bg-white/[0.03] backdrop-blur-[10px] border border-white/10 rounded-2xl p-8 shadow-[0_8px_32px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.1)] transition-all duration-300 hover:bg-white/[0.05] hover:border-[#3b82f6]/30 hover:shadow-[0_8px_32px_rgba(59,130,246,0.2),inset_0_1px_0_rgba(255,255,255,0.15)] hover:-translate-y-1 hover:scale-100">
          <h3 class="stat-number text-[clamp(2.5rem,5vw,4rem)] font-extrabold text-[#3b82f6] mb-2 leading-none">
            {stat.number}
          </h3>
          <p class="stat-label text-base text-[#a0a0a0] font-medium">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Fallback: Show stats if JavaScript fails */
  .stats:not(.js-loaded) .stat-card {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  
  /* Fallback animation after 2 seconds */
  @media (prefers-reduced-motion: no-preference) {
    .stats:not(.js-loaded) .stat-card {
      animation: fadeInUpFallback 0.1s ease-out 2s forwards;
    }
  }
  
  @keyframes fadeInUpFallback {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  @media (max-width: 968px) {
    .stats {
      margin-left: 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const { gsap } = await import('gsap');
      
      const statsSection = document.querySelector('.stats');
      if (statsSection) {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };
        
        let hasAnimated = false;
        
        const animateStats = () => {
          if (hasAnimated) return;
          hasAnimated = true;
          
          // Mark as loaded FIRST to remove CSS fallback
          statsSection.classList.add('js-loaded');
          
          const statCards = statsSection.querySelectorAll('.stat-card');
          
          // Animate cards with GSAP immediately
          gsap.from(statCards, {
            opacity: 0,
            y: 30,
            scale: 0.9,
            duration: 0.8,
            stagger: 0.1,
            ease: "power2.out"
          });
          
          // Animate numbers counting up
          statCards.forEach((card, index) => {
            const numberEl = card.querySelector('.stat-number');
            const finalValue = numberEl?.textContent || '';
            
            if (numberEl && finalValue.match(/\d+/)) {
              const numValue = parseInt(finalValue.replace(/\D/g, ''));
              if (numValue) {
                gsap.to({ value: 0 }, {
                  value: numValue,
                  duration: 1.5,
                  delay: index * 0.1 + 0.2,
                  ease: "expo.out",
                  onUpdate: function() {
                    const currentValue = Math.floor(this.targets()[0].value);
                    if (finalValue.includes('+')) {
                      numberEl.textContent = currentValue + '+';
                    } else if (finalValue.includes('K+')) {
                      numberEl.textContent = currentValue + 'K+';
                    } else {
                      numberEl.textContent = currentValue;
                    }
                  }
                });
              }
            }
          });
        };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateStats();
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        observer.observe(statsSection);
        
        // Check if already in viewport
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const rect = statsSection.getBoundingClientRect();
            const windowHeight = window.innerHeight || document.documentElement.clientHeight;
            if (rect.top < windowHeight + 200 && rect.bottom > -200) {
              animateStats();
            }
          });
        });
        
        // Fallback timeout
        setTimeout(() => {
          if (!hasAnimated) {
            animateStats();
          }
        }, 1500);
      }
    } catch (error) {
      console.error('Animation error:', error);
      document.querySelectorAll('.stat-card').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
</script>
