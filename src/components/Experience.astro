---
import { config } from '../data/config.js';
---

<section id="experience" class="experience ml-[280px] py-24">
  <div class="max-w-[1200px] mx-auto px-8">
    <h2 class="section-title text-center mb-16 text-[clamp(2rem,4vw,3rem)] opacity-0 translate-y-5">
      My Experience
    </h2>
    
    <div class="timeline max-w-[800px] mx-auto relative pl-12">
      <div class="timeline-line absolute left-0 top-0 bottom-0 w-0.5 bg-[#333]"></div>
      
      {config.experience.map((job, index) => (
        <div class="timeline-item relative pb-12 opacity-0 -translate-x-8">
          <div class="timeline-marker absolute -left-12 top-2 w-4 h-4 bg-[#3b82f6] rounded-full border-[3px] border-[#0a0a0a] shadow-[0_0_0_3px_#333]"></div>
          <div class="timeline-content bg-[#1a1a1a] rounded-lg p-8 border border-[#333] transition-all duration-300 hover:translate-x-2.5 hover:border-[#3b82f6] hover:shadow-[0_4px_12px_rgba(59,130,246,0.15)]">
            <h3 class="job-company text-2xl text-[#e0e0e0] mb-2">
              {job.company}
            </h3>
            <h4 class="job-position text-lg text-[#3b82f6] font-semibold mb-2">
              {job.position}
            </h4>
            <p class="job-duration text-sm text-[#a0a0a0] mb-4">
              {job.duration}
            </p>
            {job.description && (
              <p class="job-description text-base text-[#a0a0a0] leading-relaxed">
                {job.description}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Fallback: Show experience if JavaScript fails */
  #experience:not(.js-loaded) .section-title,
  #experience:not(.js-loaded) .timeline-item {
    opacity: 1;
    transform: none;
  }
  
  /* Fallback animation after 2 seconds */
  @media (prefers-reduced-motion: no-preference) {
    #experience:not(.js-loaded) .section-title,
    #experience:not(.js-loaded) .timeline-item {
      animation: fadeInLeftFallback 0.1s ease-out 2s forwards;
    }
  }
  
  @keyframes fadeInLeftFallback {
    to {
      opacity: 1;
      transform: none;
    }
  }
  
  @media (max-width: 968px) {
    .experience {
      margin-left: 0;
    }
    
    .timeline {
      padding-left: 2rem;
    }
    
    .timeline-marker {
      left: -2rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const { gsap } = await import('gsap');
      
      const experienceSection = document.querySelector('#experience');
      if (experienceSection) {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };
        
        let hasAnimated = false;
        
        const animateExperience = () => {
          if (hasAnimated) return;
          hasAnimated = true;
          
          const sectionTitle = experienceSection.querySelector('.section-title');
          if (sectionTitle) {
            gsap.from(sectionTitle, {
              opacity: 0,
              y: 20,
              duration: 0.8,
              ease: "expo.out"
            });
          }
          
          // Animate timeline items with stagger
          const timelineItems = experienceSection.querySelectorAll('.timeline-item');
          gsap.from(timelineItems, {
            opacity: 0,
            x: -30,
            duration: 0.8,
            stagger: 0.15,
            ease: "power2.out"
          });
          
          // Mark as loaded
          experienceSection.classList.add('js-loaded');
        };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateExperience();
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        observer.observe(experienceSection);
        
        // Check if already in viewport
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const rect = experienceSection.getBoundingClientRect();
            const windowHeight = window.innerHeight || document.documentElement.clientHeight;
            if (rect.top < windowHeight + 200 && rect.bottom > -200) {
              animateExperience();
            }
          });
        });
        
        // Fallback timeout
        setTimeout(() => {
          if (!hasAnimated) {
            animateExperience();
          }
        }, 1500);
      }
    } catch (error) {
      console.error('Animation error:', error);
      document.querySelectorAll('#experience .section-title, .timeline-item').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
</script>
