---
import { config } from '../data/config.js';
---

<section class="contact ml-[280px] py-24 text-center">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="contact-content max-w-[700px] mx-auto">
      <h2 class="contact-heading text-[clamp(2rem,5vw,3.5rem)] mb-4 text-[#e0e0e0]">
        {config.contact.heading}
      </h2>
      {config.contact.subheading && (
        <p class="contact-subheading text-xl text-[#a0a0a0] mb-10 leading-relaxed">
          {config.contact.subheading}
        </p>
      )}
      <a 
        href={`mailto:${config.personal.email}`} 
        class="contact-email inline-block text-[clamp(1.25rem,3vw,2rem)] text-[#3b82f6] font-semibold px-8 py-4 rounded-lg transition-all duration-300 hover:-translate-y-0.5 hover:text-[#2563eb]"
      >
        {config.personal.email}
      </a>
    </div>
  </div>
</section>

<style>
  @media (max-width: 968px) {
    .contact {
      margin-left: 0;
    }
    
    .contact-email {
      font-size: 1.25rem;
      word-break: break-all;
    }
  }
</style>
