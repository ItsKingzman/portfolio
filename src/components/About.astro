---
import { config } from '../data/config.js';
---

<section id="about" class="about ml-[280px] py-24">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="about-content grid grid-cols-[350px_1fr] gap-16 items-start">
      <div class="about-image relative opacity-0 -translate-x-8">
        {config.personal.avatar && (
          <img 
            src={config.personal.avatar} 
            alt={config.personal.name}
            class="w-full h-auto rounded-lg shadow-lg transition-transform duration-300 hover:scale-[1.02]"
          />
        )}
        <div class="about-image-label absolute -bottom-4 -right-4 bg-[#3b82f6] text-white px-6 py-3 rounded-lg text-sm font-semibold shadow-lg opacity-0 scale-80">
          This is me.
        </div>
      </div>
      
      <div class="about-text pt-4 opacity-0 translate-x-8">
        <h3 class="about-intro text-[clamp(1.75rem,3vw,2.5rem)] text-[#e0e0e0] mb-8">
          {config.personal.bio.intro}
        </h3>
        <div class="about-description">
          {config.personal.bio.description.split('\n\n').map(paragraph => (
            <p class="mb-6 text-lg leading-relaxed text-[#a0a0a0]">
              {paragraph}
            </p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Fallback: Show about section if JavaScript fails */
  #about:not(.js-loaded) .about-image,
  #about:not(.js-loaded) .about-text,
  #about:not(.js-loaded) .about-image-label {
    opacity: 1;
    transform: none;
  }
  
  /* Fallback animation after 2 seconds */
  @media (prefers-reduced-motion: no-preference) {
    #about:not(.js-loaded) .about-image,
    #about:not(.js-loaded) .about-text,
    #about:not(.js-loaded) .about-image-label {
      animation: fadeInFallback 0.1s ease-out 2s forwards;
    }
  }
  
  @keyframes fadeInFallback {
    to {
      opacity: 1;
      transform: none;
    }
  }
  
  @media (max-width: 968px) {
    .about {
      margin-left: 0;
    }
    
    .about-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .about-image {
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const { gsap } = await import('gsap');
      
      const aboutSection = document.querySelector('#about');
      if (aboutSection) {
        let hasAnimated = false;
        
        const animateAbout = () => {
          if (hasAnimated) return;
          hasAnimated = true;
          
          // Mark as loaded FIRST to remove CSS fallback
          aboutSection.classList.add('js-loaded');
          
          const image = aboutSection.querySelector('.about-image');
          const text = aboutSection.querySelector('.about-text');
          const label = aboutSection.querySelector('.about-image-label');
          
          // Animate image and text simultaneously
          if (image && text) {
            gsap.from([image, text], {
              opacity: 0,
              x: (index) => index === 0 ? -30 : 30,
              duration: 1,
              stagger: 0.1,
              ease: "power2.out"
            });
          }
          
          // Animate label with bounce
          if (label) {
            gsap.from(label, {
              opacity: 0,
              scale: 0.8,
              duration: 0.6,
              delay: 0.8,
              ease: "elastic.out(1, 0.8)"
            });
          }
        };
        
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateAbout();
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        observer.observe(aboutSection);
        
        // Check if already in viewport
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const rect = aboutSection.getBoundingClientRect();
            const windowHeight = window.innerHeight || document.documentElement.clientHeight;
            if (rect.top < windowHeight + 200 && rect.bottom > -200) {
              animateAbout();
            }
          });
        });
        
        // Fallback timeout
        setTimeout(() => {
          if (!hasAnimated) {
            animateAbout();
          }
        }, 1500);
      }
    } catch (error) {
      console.error('Animation error:', error);
      document.querySelectorAll('#about .about-image, .about-text, .about-image-label').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
</script>
