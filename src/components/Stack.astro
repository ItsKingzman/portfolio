---
import { config } from '../data/config.js';
---

<section class="stack ml-[280px] py-24 bg-[#1a1a1a]">
  <div class="max-w-[1200px] mx-auto px-8">
    <h2 class="section-title text-center mb-16 text-[clamp(2rem,4vw,3rem)] opacity-0 translate-y-5">
      My Stack
    </h2>
    
    {config.stack.frontend && config.stack.frontend.length > 0 && (
      <div class="stack-category mb-16 opacity-0 translate-y-8">
        <h3 class="category-title text-base font-semibold tracking-wider text-[#a0a0a0] mb-8">
          Frontend
        </h3>
        <div class="tech-grid grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] gap-8">
          {config.stack.frontend.map(tech => (
            <div class="tech-item flex flex-col items-center gap-4 p-6 bg-[#0a0a0a] rounded-lg border border-[#333] transition-all duration-300 hover:-translate-y-1.5 hover:scale-[1.02] hover:border-[#3b82f6] hover:shadow-[0_8px_16px_rgba(59,130,246,0.2)] opacity-0 translate-y-5 scale-95">
              <div class="tech-logo w-12 h-12 flex items-center justify-center">
                <img src={tech.logo} alt={tech.name} width="48" height="48" class="w-full h-full object-contain" />
              </div>
              <span class="tech-name text-sm text-center text-[#e0e0e0] font-medium">
                {tech.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}
    
    {config.stack.cms && config.stack.cms.length > 0 && (
      <div class="stack-category mb-16 opacity-0 translate-y-8">
        <h3 class="category-title text-base font-semibold tracking-wider text-[#a0a0a0] mb-8">
          CMS
        </h3>
        <div class="tech-grid grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] gap-8">
          {config.stack.cms.map(tech => (
            <div class="tech-item flex flex-col items-center gap-4 p-6 bg-[#0a0a0a] rounded-lg border border-[#333] transition-all duration-300 hover:-translate-y-1.5 hover:scale-[1.02] hover:border-[#3b82f6] hover:shadow-[0_8px_16px_rgba(59,130,246,0.2)] opacity-0 translate-y-5 scale-95">
              <div class="tech-logo w-12 h-12 flex items-center justify-center">
                <img src={tech.logo} alt={tech.name} width="48" height="48" class="w-full h-full object-contain" />
              </div>
              <span class="tech-name text-sm text-center text-[#e0e0e0] font-medium">
                {tech.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}
    
    {config.stack.tools && config.stack.tools.length > 0 && (
      <div class="stack-category mb-16 opacity-0 translate-y-8">
        <h3 class="category-title text-base font-semibold tracking-wider text-[#a0a0a0] mb-8">
          Tools
        </h3>
        <div class="tech-grid grid grid-cols-[repeat(auto-fill,minmax(120px,1fr))] gap-8">
          {config.stack.tools.map(tech => (
            <div class="tech-item flex flex-col items-center gap-4 p-6 bg-[#0a0a0a] rounded-lg border border-[#333] transition-all duration-300 hover:-translate-y-1.5 hover:scale-[1.02] hover:border-[#3b82f6] hover:shadow-[0_8px_16px_rgba(59,130,246,0.2)] opacity-0 translate-y-5 scale-95">
              <div class="tech-logo w-12 h-12 flex items-center justify-center">
                <img src={tech.logo} alt={tech.name} width="48" height="48" class="w-full h-full object-contain" />
              </div>
              <span class="tech-name text-sm text-center text-[#e0e0e0] font-medium">
                {tech.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  /* Fallback: Show stack if JavaScript fails */
  .stack:not(.js-loaded) .section-title,
  .stack:not(.js-loaded) .stack-category,
  .stack:not(.js-loaded) .tech-item {
    opacity: 1;
    transform: none;
  }
  
  /* Fallback animation after 2 seconds */
  @media (prefers-reduced-motion: no-preference) {
    .stack:not(.js-loaded) .section-title,
    .stack:not(.js-loaded) .stack-category,
    .stack:not(.js-loaded) .tech-item {
      animation: fadeInFallback 0.1s ease-out 2s forwards;
    }
  }
  
  @keyframes fadeInFallback {
    to {
      opacity: 1;
      transform: none;
    }
  }
  
  @media (max-width: 968px) {
    .stack {
      margin-left: 0;
    }
    
    .tech-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    try {
      const { gsap } = await import('gsap');
      
      const stackSection = document.querySelector('.stack');
      if (stackSection) {
        let hasAnimated = false;
        
        const animateStack = () => {
          if (hasAnimated) return;
          hasAnimated = true;
          
          const sectionTitle = stackSection.querySelector('.section-title');
          if (sectionTitle) {
            gsap.from(sectionTitle, {
              opacity: 0,
              y: 20,
              duration: 0.8,
              ease: "expo.out"
            });
          }
          
          // Animate categories with stagger
          const categories = stackSection.querySelectorAll('.stack-category');
          categories.forEach((category, index) => {
            gsap.from(category, {
              opacity: 0,
              y: 30,
              duration: 0.8,
              delay: index * 0.2,
              ease: "expo.out"
            });
            
            // Animate tech items within category
            const techItems = category.querySelectorAll('.tech-item');
            gsap.from(techItems, {
              opacity: 0,
              y: 20,
              scale: 0.95,
              duration: 0.6,
              delay: index * 0.2 + 0.3,
              stagger: 0.05,
              ease: "power2.out"
            });
          });
          
          // Mark as loaded
          stackSection.classList.add('js-loaded');
        };
        
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateStack();
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);
        
        observer.observe(stackSection);
        
        // Check if already in viewport
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const rect = stackSection.getBoundingClientRect();
            const windowHeight = window.innerHeight || document.documentElement.clientHeight;
            if (rect.top < windowHeight + 200 && rect.bottom > -200) {
              animateStack();
            }
          });
        });
        
        // Fallback timeout
        setTimeout(() => {
          if (!hasAnimated) {
            animateStack();
          }
        }, 1500);
      }
    } catch (error) {
      console.error('Animation error:', error);
      document.querySelectorAll('.stack .section-title, .stack-category, .tech-item').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    }
  });
</script>
